generator client {
  provider = "prisma-client-js"
}

// URL подключения — в prisma.config.ts (Prisma 7+).
// Здесь остаётся только provider.
datasource db {
  provider = "postgresql"
}

// ─── Пользователь ───────────────────────────────────────────
// telegramId — внешний идентификатор из Telegram, хранится как BigInt
// потому что Telegram ID может превышать 2^31 (лимит обычного Int).
// Внутренний id (autoincrement) используется для FK в других таблицах —
// это стандартный паттерн: внешний идентификатор ≠ первичный ключ.
model User {
  id             Int      @id @default(autoincrement())
  telegramId     BigInt   @unique @map("telegram_id")
  firstName      String   @map("first_name")
  username       String?
  languageCode   String?  @map("language_code")
  createdAt      DateTime @default(now()) @map("created_at")
  currentStreak  Int      @default(0) @map("current_streak")
  longestStreak  Int      @default(0) @map("longest_streak")
  totalXp        Int      @default(0) @map("total_xp")
  dailyGoal      Int      @default(50) @map("daily_goal")
  dailyXp        Int      @default(0) @map("daily_xp")
  dailyXpDate    DateTime? @map("daily_xp_date")
  // IANA tz юзера (например "Europe/Moscow"). null = считаем по UTC.
  // Клиент шлёт в заголовке X-Timezone, сервер сохраняет здесь.
  timezone       String?
  lastActivityAt DateTime? @map("last_activity_at")

  // Связь один-ко-многим: у юзера много записей прогресса
  lessonProgress  LessonProgress[]
  // Расписание повторений (spaced repetition по SM-2)
  reviewSchedule  ReviewSchedule[]
  // Полученные ачивки
  achievements    UserAchievement[]

  @@map("users")
}

// ─── Прогресс по уроку ──────────────────────────────────────
// Одна запись = один юзер + один урок.
// @@unique([userId, lessonSlug]) гарантирует отсутствие дублей
// и одновременно работает как индекс для быстрого поиска
// "прогресс юзера X по уроку Y".
model LessonProgress {
  id             Int            @id @default(autoincrement())
  userId         Int            @map("user_id")
  lessonSlug     String         @map("lesson_slug")
  status         LessonStatus   @default(STARTED)
  startedAt      DateTime       @default(now()) @map("started_at")
  completedAt    DateTime?      @map("completed_at")
  bestScore      Int?           @map("best_score")
  attemptsCount  Int            @default(0) @map("attempts_count")

  // FK: связь с таблицей users
  user User @relation(fields: [userId], references: [id])

  // Составной уникальный индекс: один юзер — одна запись на урок
  @@unique([userId, lessonSlug])
  @@map("lesson_progress")
}

// ─── Enum: статус прохождения урока ─────────────────────────
// STARTED — открыл урок, ещё не прошёл тест
// COMPLETED — прошёл тест (bestScore записан)
enum LessonStatus {
  STARTED
  COMPLETED
}

// ─── Ачивки пользователя ────────────────────────────────────
// Одна запись = факт получения ачивки (userId + achievementId).
// Сами определения ачивок — в коде (lib/achievements.ts), не в БД.
// Это позволяет добавлять новые ачивки без миграций.
model UserAchievement {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  achievementId String   @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// ─── Расписание повторений (spaced repetition) ─────────────
// Одна запись = состояние SM-2 для пары (юзер, конкретный вопрос).
// Алгоритм SM-2 после каждого ответа пересчитывает easeFactor + intervalDays
// и записывает next_review_at = now() + interval_days.
// Главный запрос приложения: "что повторять сегодня?":
//   WHERE user_id=? AND next_review_at <= NOW()
// Индекс @@index([userId, nextReviewAt]) делает его O(log n).
model ReviewSchedule {
  id             Int       @id @default(autoincrement())
  userId         Int       @map("user_id")

  // Идентификация вопроса: slug урока + id вопроса из quiz.json.
  // Связки с questions нет в БД (вопросы — это файлы), отсюда строки, а не FK.
  lessonSlug     String    @map("lesson_slug")
  questionId     String    @map("question_id")

  // SM-2 state. Все три поля имеют дефолты, чтобы при первом создании
  // вопрос сразу попадал в выдачу «к повтору» (nextReviewAt = now()).
  easeFactor     Float     @default(2.5) @map("ease_factor")
  intervalDays   Int       @default(0)   @map("interval_days")
  repetitions    Int       @default(0)

  // Тайминги
  nextReviewAt   DateTime  @default(now()) @map("next_review_at")
  lastReviewedAt DateTime? @map("last_reviewed_at")

  user User @relation(fields: [userId], references: [id])

  // Один юзер — одна запись на конкретный вопрос
  @@unique([userId, lessonSlug, questionId])
  // Ускоряет основной запрос "что показать сегодня"
  @@index([userId, nextReviewAt])
  @@map("review_schedule")
}
